#include <stdio.h>
#include <stdlib.h>
#include <locale.h>


int main() {
    int quantidade = 1, numero, impares = 0;
    
    printf("\n****************************************\n");
    printf("*Aluna: IORRANA DE SOUZA HIPOLITO - RA: 0025980 *");
    printf("\n*Programa PJA-42 - Quantidade de números ímpares digitados  *");
    printf("\n****************************\n");


    while (quantidade <= 10) {
        printf("Digite o %dº numero: ", quantidade);
        scanf("%d", &numero);

        // Se o resto da divisão por 2 for diferente de 0, o número é ímpar
        if (numero % 2 != 0) {
            impares++;
        }
        quantidade++;
    }

    printf("\nVoce digitou %d numeros impares.\n", impares);

    return 0;
}
