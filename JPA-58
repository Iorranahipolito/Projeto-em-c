#include <stdio.h>
#include <stdlib.h>
#include <locale.h>

int main() {
    setlocale(LC_ALL, "Portuguese");

    printf("\n*****************************************************************");
    printf("\n* Aluno:IORRANA DE SOUZA HIPOLITO - RA: 0025980                 *");
    printf("\n* Programa JPA-58: Calculadora de Bolso (SWITCH...CASE)         *");
    printf("\n*************************************************************\n\n");

    float num1, num2;
    char operacao;

    printf("Digite o primeiro número: ");
    scanf("%f", &num1);
    printf("Digite o segundo número: ");
    scanf("%f", &num2);
    printf("Digite a operação matemática (+, -, *, /): ");
    scanf(" %c", &operacao);

    printf("\nResultado: ");
    switch (operacao) {
        case '+':
            printf("%.2f + %.2f = %.2f\n", num1, num2, num1 + num2);
            break;
        case '-':
            printf("%.2f - %.2f = %.2f\n", num1, num2, num1 - num2);
            break;
        case '*':
            printf("%.2f * %.2f = %.2f\n", num1, num2, num1 * num2);
            break;
        case '/':
            if (num2 != 0) {
                printf("%.2f / %.2f = %.2f\n", num1, num2, num1 / num2);
            } else {
                printf("Erro matemático! Divisão por zero não é permitida.\n");
            }
            break;
        default:
            printf("Operação matemática não reconhecida.\n");
            break;
    }

    return 0;
}
